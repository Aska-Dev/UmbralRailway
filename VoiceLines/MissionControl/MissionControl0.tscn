[node name="MissionControl0" type="AudioStreamPlayer" unique_id=1370163807]
stream = ExtResource("1_ly0ri")
volume_db = -5.0
script = ExtResource("2_xq3fi")
VoiceLineText = "Hello and welcome to our programm. I hope your journey went smoothly. Unsuprisingly there were some problems with logistics - so we don't have your files yet. Let's see... train number 171004, hm?//Well... let's just call you 171 for now.  I don't know how much they told you down at Earth, but we're basically just here to clean up their mess. Nothing fancy, but it pays good at least.//Icarus abandoned this research facility after the project failed to meet expectations. Still, a lot of the equipment can be used for other experiments at other facilities. After all, it's expensive to shoot things to the moon.//As a train operator you will drive this train through the deserted site and, well, do whatever needs to be done. If you have any questions you should find a manual somewhere, that explains everything you need to know.//Now, go on and make yourself familiar with... well, everything and just drive forward to reach Gehenna Station. We will contact you again when you reached it. Good luck. Mission Control out."

